    {
      "name": "Funding & Topup",
      "description": "Add funds to the account — bank wire instructions, simulate deposits in sandbox.",
      "item": [
        {
          "name": "Get Topup Instructions (Bank Wire)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/global-accounts/{{account_id}}/topup-instructions?currency=USD",
              "host": ["{{base_url}}"],
              "path": ["global-accounts", "{{account_id}}", "topup-instructions"],
              "query": [
                { "key": "currency", "value": "USD" },
                { "key": "rail", "value": "ach", "disabled": true },
                { "key": "rail", "value": "swift", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Simulate Deposit (Sandbox only)",
          "request": {
            "method": "POST",
            "header": [
