    {
      "name": "FX (Currency Exchange)",
      "description": "Get rates, request a quote, execute a conversion between currencies inside the account.",
      "item": [
        {
          "name": "Get FX Rates",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/fx/rates?from=USD&to=EUR",
              "host": ["{{base_url}}"],
              "path": ["fx", "rates"],
              "query": [
                { "key": "from", "value": "USD" },
                { "key": "to",   "value": "EUR" }
              ]
            }
          }
        },
        {
          "name": "Request FX Quote",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-idempotency-key", "value": "{{$guid}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"from_currency\": \"USD\",\n  \"to_currency\": \"EUR\",\n  \"amount\": \"1000.00\",\n  \"amount_type\": \"source\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/global-accounts/{{account_id}}/fx/quotes",
              "host": ["{{base_url}}"],
              "path": ["global-accounts", "{{account_id}}", "fx", "quotes"]
            }
          }
        },
        {
          "name": "Execute FX Conversion",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-idempotency-key", "value": "{{$guid}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quote_id\": \"{{quote_id}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/global-accounts/{{account_id}}/fx/conversions",
              "host": ["{{base_url}}"],
              "path": ["global-accounts", "{{account_id}}", "fx", "conversions"]
            }
          }
        },
        {
          "name": "List FX Conversions",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/global-accounts/{{account_id}}/fx/conversions?page_size=20&page_number=1",
              "host": ["{{base_url}}"],
              "path": ["global-accounts", "{{account_id}}", "fx", "conversions"],
              "query": [
                { "key": "page_size", "value": "20" },
                { "key": "page_number", "value": "1" }
              ]
            }
          }
        }
      ]
    },
