    {
      "name": "Payouts",
      "description": "Send money from the global account to a beneficiary.",
      "item": [
        {
          "name": "List Payouts",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/global-accounts/{{account_id}}/payouts?page_size=20&page_number=1",
              "host": ["{{base_url}}"],
              "path": ["global-accounts", "{{account_id}}", "payouts"],
              "query": [
                { "key": "page_size", "value": "20" },
                { "key": "page_number", "value": "1" },
                { "key": "status", "value": "completed", "disabled": true },
                { "key": "currency", "value": "USD", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Create Payout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-idempotency-key", "value": "{{$guid}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"beneficiary_id\": \"{{beneficiary_id}}\",\n  \"source_currency\": \"USD\",\n  \"destination_currency\": \"GBP\",\n  \"amount\": \"500.00\",\n  \"amount_type\": \"source\",\n  \"purpose\": \"goods-payment\",\n  \"reference\": \"INV-2025-001\",\n  \"description\": \"Payment for invoice INV-2025-001\",\n  \"metadata\": {\n    \"invoice_id\": \"INV-2025-001\"\n  }\n}"
