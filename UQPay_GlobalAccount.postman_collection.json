    {
      "name": "KYC / KYB",
      "description": "Submit and check identity verification documents.",
      "item": [
        {
          "name": "Submit KYC (Individual)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-idempotency-key", "value": "{{$guid}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identity\": {\n    \"type\": \"PASSPORT\",\n    \"number\": \"A12345678\",\n    \"issue_date\": \"2020-01-01\",\n    \"expiry_date\": \"2030-01-01\",\n    \"issuing_country\": \"US\"\n  },\n  \"documents\": {\n    \"id_front_file_id\": \"file_xxxxx\",\n    \"id_back_file_id\": \"file_yyyyy\",\n    \"selfie_file_id\": \"file_zzzzz\"\n  }\n}"
            },
            "url": {
