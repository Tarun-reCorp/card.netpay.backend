{
  "info": {
    "_postman_id": "a8c6e2d4-9b3a-4f0e-bd1c-ec1234567890",
    "name": "UQPay Global Account API",
    "description": "Comprehensive Postman collection for UQPay Global Account API endpoints — sandbox.\n\n**Base URL (sandbox)**: `https://api-sandbox.uqpaytech.com/api/v1`\n**Base URL (prod)**:    `https://api.uqpaytech.com/api/v1`\n\nNo authentication is wired (test mode). Add `Authorization` headers, `x-api-key`, `x-client-id` or `x-idempotency-key` as your environment requires.\n\nVariables:\n- `base_url` — flip between sandbox and prod\n- `account_id` — global account id used in path\n- `beneficiary_id` — beneficiary id\n- `payout_id`, `txn_id`, `quote_id` — for entity-level lookups\n",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "description": "OAuth2 / token endpoints. Add credentials in body once you wire auth.",
      "item": [
        {
          "name": "Get Access Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-api-key", "value": "{{api_key}}" },
              { "key": "x-client-id", "value": "{{client_id}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"grant_type\": \"client_credentials\",\n  \"client_id\": \"{{client_id}}\",\n  \"client_secret\": \"{{client_secret}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/connect/token",
              "host": ["{{base_url}}"],
              "path": ["connect", "token"]
            }
          }
        }
      ]
    },
    {
      "name": "Global Accounts",
      "description": "Account lifecycle — create, list, get, update.",
      "item": [
        {
          "name": "Create Global Account",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-idempotency-key", "value": "{{$guid}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"account_holder_type\": \"individual\",\n  \"account_holder\": {\n    \"first_name\": \"John\",\n    \"last_name\": \"Doe\",\n    \"email\": \"john.doe@example.com\",\n    \"phone_number\": \"5551234567\",\n    \"country_code\": \"US\",\n    \"date_of_birth\": \"1990-01-01\",\n    \"address\": {\n      \"line1\": \"123 Main St\",\n      \"city\": \"New York\",\n      \"state\": \"NY\",\n      \"postal_code\": \"10001\",\n      \"country\": \"US\"\n    }\n  },\n  \"base_currency\": \"USD\",\n  \"sub_currencies\": [\"EUR\", \"GBP\", \"AED\"],\n  \"metadata\": {\n    \"external_id\": \"user_12345\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/global-accounts",
              "host": ["{{base_url}}"],
              "path": ["global-accounts"]
            }
          }
        },
        {
          "name": "List Global Accounts",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/global-accounts?page_size=20&page_number=1",
              "host": ["{{base_url}}"],
              "path": ["global-accounts"],
              "query": [
                { "key": "page_size", "value": "20" },
                { "key": "page_number", "value": "1" },
                { "key": "status", "value": "active", "disabled": true },
                { "key": "currency", "value": "USD", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Global Account",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/global-accounts/{{account_id}}",
              "host": ["{{base_url}}"],
              "path": ["global-accounts", "{{account_id}}"]
            }
          }
        },
        {
          "name": "Update Global Account",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-idempotency-key", "value": "{{$guid}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"account_holder\": {\n    \"phone_number\": \"5559876543\",\n    \"address\": {\n      \"line1\": \"456 Park Ave\",\n      \"city\": \"New York\",\n      \"state\": \"NY\",\n      \"postal_code\": \"10002\",\n      \"country\": \"US\"\n    }\n  },\n  \"metadata\": {\n    \"updated_reason\": \"customer-request\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/global-accounts/{{account_id}}",
              "host": ["{{base_url}}"],
              "path": ["global-accounts", "{{account_id}}"]
            }
          }
        },
        {
          "name": "Update Account Status (freeze/unfreeze/close)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-idempotency-key", "value": "{{$guid}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"frozen\",\n  \"reason\": \"compliance-review\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/global-accounts/{{account_id}}/status",
              "host": ["{{base_url}}"],
              "path": ["global-accounts", "{{account_id}}", "status"]
            }
          }
        }
      ]
    },
