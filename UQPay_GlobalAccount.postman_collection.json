            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": \"1000.00\",\n  \"currency\": \"USD\",\n  \"source\": \"sandbox-test\",\n  \"reference\": \"sandbox-deposit-{{$timestamp}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/global-accounts/{{account_id}}/simulate/deposit",
              "host": ["{{base_url}}"],
              "path": ["global-accounts", "{{account_id}}", "simulate", "deposit"]
            }
          }
        }
      ]
    },
