PORT=5000
FRONTEND_URL=http://localhost:5173
MONGO_URI=mongodb://localhost:27017/netpay_cards

# JWT Secrets
JWT_SECRET=your_jwt_secret_here
JWT_ADMIN_SECRET=your_admin_jwt_secret_here
JWT_MERCHANT_SECRET=your_merchant_jwt_secret_here
JWT_EXPIRES_IN=7d

# API Key for card API routes
API_KEY=your_api_key_here

# UQPay Card Provider API (sandbox URL by default)
UQPAY_API_URL=https://api-sandbox.uqpaytech.com/api/v1
UQPAY_API_KEY=your_uqpay_api_key_here
UQPAY_CLIENT_ID=your_uqpay_client_id_here

# Encryption key for wallet mnemonics (32 bytes hex)
ENCRYPTION_KEY=your_32_byte_hex_encryption_key

# File upload (local or S3)
UPLOAD_DRIVER=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET=
AWS_REGION=

# 2FA App name
APP_NAME=NetPay Cards
